# Copy this file to `.env` and fill in your key. `.env` is gitignored.
#   cp .env.template .env

# Used by the OpenRouter backend (AgentSpec backend="openrouter", the `partnuh`
# command, and examples/chat.py + examples/smol.py).
OPENROUTER_API_KEY=sk-or-your-key-here

# Optional: model id for the `partnuh` console command and examples.
PARTNUH_MODEL=openai/gpt-5.4-nano

# Note: examples/fake.py needs NONE of this — it runs with a made-up agent,
# no key and no network.
